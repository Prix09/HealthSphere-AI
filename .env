# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=healthsphere_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DO NOT use port 5433 per requirements, so we stick to 5432.
# Using 'postgres' as host because within docker network that's the service name.

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@healthsphere.ai
PGADMIN_DEFAULT_PASSWORD=admin

# Kafka
KAFKA_BROKER=kafka:29092
ZOOKEEPER_HOST=zookeeper:2181

# Spark
SPARK_MASTER_URL=spark://spark-master:7077

# FastAPI Backend
SECRET_KEY=supersecretkeythatshouldbechangedinproduction
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
